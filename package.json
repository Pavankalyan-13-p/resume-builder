{
  "name": "resume-builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "npx puppeteer browsers install chrome",
    "start": "node server/index.js",
    "dev": "concurrently -n \"vite,pdf\" -c \"cyan,yellow\" \"vite\" \"node server/index.js\"",
    "dev:vite": "vite",
    "build": "vite build && npx puppeteer browsers install chrome",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "puppeteer": "^24.0.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.5"
  }
