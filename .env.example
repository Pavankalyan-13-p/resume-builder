# ─── LOCAL DEV ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# ─── FRONTEND env vars (Vite — must be prefixed VITE_) ────────────────────────
# Local dev: both point to the local dev server.
# Vercel production: set both to https://<your-render-service>.onrender.com
VITE_PDF_SERVER_URL=http://localhost:3001
VITE_AI_SERVER_URL=http://localhost:3001

# ─── BACKEND env vars (server/index.js — set these in the Render dashboard) ───

# Comma-separated origins allowed to call the API.
# Render dashboard value:
#   https://<your-vercel-app>.vercel.app,http://localhost:5173,http://localhost:4173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Razorpay — get from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# Gemini AI — get from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.5-flash   # optional, this is the default

# Firebase server-side lookups (same value as VITE_FIREBASE_API_KEY / PROJECT_ID)
FIREBASE_WEB_API_KEY=YOUR_FIREBASE_WEB_API_KEY
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID

# ─── Firebase (Vite — set in Vercel dashboard for production) ─────────────────
# Get from: Firebase Console > Project settings > Your apps > Web app config
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
